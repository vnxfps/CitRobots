@model CarrinhoViewModel

<div class="cart-container">
    <h2>Seu Carrinho</h2>

    @if (Model.Items.Any())
    {
        <div class="cart-items">
            @foreach (var item in Model.Items)
            {
                <div class="cart-item">
                    <img src="@item.Robot.ImagemUrl" alt="@item.Robot.Nome" />
                    <div class="item-info">
                        <h3>@item.Robot.Nome</h3>
                        <p>Personalizações:</p>
                        <ul>
                            @foreach (var p in item.Personalizacoes)
                            {
                                <li>@p.Nome</li>
                            }
                        </ul>
                        <p class="price">R$ @item.Preco.ToString("N2")</p>
                    </div>
                    <form asp-action="RemoveItem" method="post">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <button type="submit" class="btn btn-danger">
                            Remover
                        </button>
                    </form>
                </div>
            }
        </div>

        <div class="cart-summary">
            <div class="cupom-area">
                <input type="text" id="cupomCodigo" placeholder="Código do cupom" />
                <button onclick="aplicarCupom()" class="btn btn-secondary">
                    Aplicar Cupom
                </button>
            </div>

            <div class="total">
                <p>Total: R$ @Model.Total.ToString("N2")</p>
            </div>

            <a href="@Url.Action("Checkout", "Pedido")"
               class="btn btn-primary btn-lg">
                Finalizar Compra
            </a>
        </div>
    }
    else
    {
        <p>Seu carrinho está vazio</p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            Continuar Comprando
        </a>
    }
</div>