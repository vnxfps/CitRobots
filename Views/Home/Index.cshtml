@{
    ViewData["Title"] = "Início";
}

<div class="hero-section" id="animated-container">
    <h1 class="main-slogan">Transforme cada treino em uma vitória!</h1>
    <p class="sub-slogan">Liberte o potencial máximo do seu time com CitRobots — mais precisão, mais inteligência, mais vitórias.</p>
</div>

<div class="robots-grid">
    @foreach (var robot in Model)
    {
        <div class="robot-card">
            <img src="@robot.ImagemUrl" alt="@robot.Nome">
            <h2>@robot.Nome</h2>
            <p class="slogan">@robot.Slogan</p>
            <p class="price">@robot.Preco.ToString("C")</p>
            <a asp-controller="Robots" asp-action="Customize" asp-route-id="@robot.Id" class="customize-btn">
                Personalizar
            </a>
        </div>
    }
</div>